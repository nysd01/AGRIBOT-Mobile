# ── AGRI-PC edge hub configuration ─────────────────────────────────────────────
# Copy to ".env" and edit. Never commit the real .env.

# HTTP server (the phone calls this; bind 0.0.0.0 so the hotspot can reach it)
HOST=0.0.0.0
PORT=8000

# Postgres (install Postgres on AGRI-PC; create db + user to match)
DATABASE_URL=postgresql://agribot:agribot@localhost:5432/agribot_edge

# Camera + mic — Windows DirectShow device names.
# Find exact names with:  ffmpeg -list_devices true -f dshow -i dummy
VIDEO_DEVICE=Integrated Camera
AUDIO_DEVICE=Microphone Array
MEDIA_FORMAT=dshow

# Stream tuning — lower = less latency/bandwidth (good for remote/TURN driving).
VIDEO_WIDTH=640
VIDEO_HEIGHT=360
VIDEO_FRAMERATE=20

# WebRTC ICE — STUN is enough on the LAN (offline). For ONLINE (phone remote,
# AGRI-PC behind NAT) you MUST also set a TURN server, or the media won't connect.
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

# Local MQTT broker (Mosquitto on AGRI-PC). ESP32-Sensors publishes JSON here.
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_SENSORS_TOPIC=agribot/sensors

# Supabase sync (push offline rows up when internet is available).
# Use the SERVICE ROLE key here (server-side only — never ship this in the app).
SUPABASE_URL=https://nthjehbwyuxwtwvcodeg.supabase.co
SUPABASE_SERVICE_KEY=
SYNC_INTERVAL_S=30
