{
  "title": "AGRIBOT API — Monitoring",
  "uid": "agribot-api",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m]))",
          "legendFormat": "requests/s"
        }
      ]
    },
    {
      "id": 2,
      "title": "Requests by status code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "In-progress requests",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(http_requests_inprogress)",
          "legendFormat": "in progress"
        }
      ]
    },
    {
      "id": 5,
      "title": "🌱 Sensor readings ingested (ESP32 → API, req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/(api/)?readings\", method=\"POST\"}[1m]))",
          "legendFormat": "readings/s"
        }
      ]
    },
    {
      "id": 6,
      "title": "🌱 Total readings ingested",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "targets": [
        {
          "expr": "sum(http_requests_total{handler=~\"/(api/)?readings\", method=\"POST\"})",
          "legendFormat": "total"
        }
      ]
    }
  ]
}
