// AGRIBOT API — CI/CD pipeline (rubric §3, 10 marks)
// Stages: Checkout -> Install -> Test(80% gate) -> Build image -> Deploy -> Smoke test
pipeline {
    agent any

    environment {
        IMAGE     = 'agribot-api:latest'
        APP_DIR   = 'agribot-api'
        CI_PROJECT = 'agribot-ci'   // isolated compose project for CI (won't touch the demo stack)
        CI_PORT   = '18090'          // dedicated host port for the CI deploy
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Building commit ${env.GIT_COMMIT ?: 'local'}"
            }
        }

        stage('Install deps') {
            steps {
                dir("${APP_DIR}") {
                    sh '''
                        python3 -m venv .venv
                        . .venv/bin/activate
                        pip install --upgrade pip
                        pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Test (80% coverage gate)') {
            steps {
                dir("${APP_DIR}") {
                    // pytest.ini enforces --cov-fail-under=80; build fails if coverage drops.
                    sh '''
                        . .venv/bin/activate
                        pytest --junitxml=report.xml
                    '''
                }
            }
            post {
                always {
                    junit "${APP_DIR}/report.xml"
                    // Always keep the coverage report as a build artifact (no plugin needed).
                    archiveArtifacts artifacts: "${APP_DIR}/htmlcov/**", allowEmptyArchive: true
                    // Nicely rendered coverage report IF the HTML Publisher plugin is installed;
                    // wrapped so a missing plugin can't fail the build.
                    script {
                        try {
                            publishHTML(target: [
                                reportDir: "${APP_DIR}/htmlcov",
                                reportFiles: 'index.html',
                                reportName: 'Coverage Report',
                                keepAll: true, alwaysLinkToLastBuild: true, allowMissing: true
                            ])
                        } catch (err) {
                            echo "HTML Publisher plugin not installed — coverage report archived as an artifact instead."
                        }
                    }
                }
            }
        }

        stage('Build image') {
            steps {
                dir("${APP_DIR}") {
                    sh 'docker build -t ${IMAGE} .'
                }
            }
        }

        stage('Deploy') {
            steps {
                dir("${APP_DIR}") {
                    // Deploy an isolated CI stack (own project + own port) so it never
                    // collides with the demo stack the marker sees on the default port.
                    sh '''
                        API_PORT=${CI_PORT} docker compose -p ${CI_PROJECT} up -d --build
                    '''
                }
            }
        }

        stage('Smoke test') {
            steps {
                // Retry: Postgres needs a few seconds before the API's first boot succeeds.
                sh '''
                    for i in $(seq 1 10); do
                        curl -fsS http://localhost:${CI_PORT}/health && exit 0
                        echo "waiting for API... ($i)"; sleep 3
                    done
                    echo "API did not become healthy in time"; exit 1
                '''
            }
        }
    }

    post {
        success { echo '✅ Pipeline green — tested, built, deployed.' }
        failure { echo '❌ Pipeline failed — check the failing stage above.' }
    }
}
